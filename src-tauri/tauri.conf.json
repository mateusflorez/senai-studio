{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumen Studio",
  "version": "1.2.2",
  "identifier": "com.bombe.lumen-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lumen Studio",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFRUY1RDlDMjI1MzBFQTQKUldTa0RsTWluRjN2YnJ2TlNHTE4yTmFpemxRdW8zTFZTM3pZU0pJamMxUlNneGk1dzNsMGVOdlcK",
      "endpoints": [
        "https://mateusflorez.github.io/lumen-studio/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/lumen-studio-installer.ico",
        "headerImage": "icons/header.bmp",
        "sidebarImage": "icons/side.bmp"
      }
    },
    "resources": [
      "resources/windows-runtime/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
